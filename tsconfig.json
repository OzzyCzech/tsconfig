{
	"compilerOptions": {
		"incremental": true, // Enable incremental compilation for faster builds.
		"outDir": "${configDir}/dist", // Use ${configDir} so the output resolves relative to the consuming tsconfig, not this file.
		"module": "nodenext", // Modern Node.js ESM emit; matches runtime semantics (file extensions in imports, package.json "type" respected).
		"moduleResolution": "nodenext", // Paired with module: nodenext. Replaces the legacy "node" resolver.
		"moduleDetection": "force", // Treat every file as a module, even without imports/exports. Avoids accidental script-scope leaks.
		"allowSyntheticDefaultImports": true, // Type-check default imports of CommonJS modules as if they had a default export.
		"esModuleInterop": true, // Emits runtime interop helpers so CommonJS default/namespace imports work correctly.
		"target": "esnext", // Emit modern JS; runtime is guaranteed by engines.node and runtime lib choices.
		"lib": ["ES2024"], // Node 22+ / Bun support ES2024. No DOM here — use @ozzyczech/tsconfig/dom for browser code.
		"resolveJsonModule": true, // Allow importing .json files (needed with ESM import attributes at runtime).
		"declaration": true, // Emit .d.ts type declarations for published libraries.
		"newLine": "lf", // Force LF line endings in emitted files across platforms.
		"stripInternal": true, // Omit members marked with /** @internal */ from declaration output.
		"strict": true, // Enable all strict type-checking options.
		"erasableSyntaxOnly": true, // Disallow non-erasable syntax (enums, parameter properties, namespaces) so output stays compatible with type-stripping runtimes like Node/Bun/tsx.
		"noImplicitReturns": true, // Every code path in a function must return a value.
		"noImplicitOverride": true, // Require the `override` keyword when overriding a base class method.
		"noUnusedLocals": true, // Error on unused local variables.
		"noUnusedParameters": true, // Error on unused function parameters.
		"noFallthroughCasesInSwitch": true, // Error on switch cases that fall through without break/return.
		"noUncheckedIndexedAccess": true, // Indexed access returns T | undefined — forces explicit handling.
		"noPropertyAccessFromIndexSignature": false, // Allow dot-access on index signatures (less noise when working with dynamic objects).
		"noUncheckedSideEffectImports": true, // Verify that side-effect-only imports resolve to real modules.
		"noEmitOnError": true, // Don't write output files if there are type errors.
		"useDefineForClassFields": true, // Use ECMAScript `[[Define]]` semantics for class fields (standard behavior).
		"skipLibCheck": true, // Skip type-checking of .d.ts in node_modules for faster builds.
		"isolatedModules": true // Each file must be transpilable in isolation (required by esbuild, swc, Babel, Bun).
	},
	"exclude": ["${configDir}/dist"]
}
