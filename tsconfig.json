{
	"compilerOptions": {
		"incremental": true, // Enable incremental compilation for faster builds.
		"outDir": "${configDir}/dist", // Use a variable for the output directory to allow for dynamic configuration.
		"module": "esnext", // Use the latest ECMAScript module system for better compatibility with modern JavaScript.
		"moduleResolution": "node", // Use Node.js module resolution strategy for better compatibility with Node.js and modern JavaScript tooling.
		"moduleDetection": "force", // Force module detection to ensure that all files are treated as modules, which is useful for projects that mix ESM and CommonJS.
		"allowSyntheticDefaultImports": true, // Allows default imports from modules that don't have a default export, which is useful for compatibility with CommonJS modules.
		"esModuleInterop": true, // Emits runtime interop helpers for CommonJS default/namespace imports; pairs with allowSyntheticDefaultImports for correct type-check + runtime behavior.
		"target": "esnext", // Target the latest ECMAScript version for better performance and features.
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES2023"
		], // Include the latest DOM and ECMAScript libraries for better type support.
		"resolveJsonModule": false, // Disable JSON module resolution for ESM, as it is not yet fully supported.
		"jsx": "react-jsx", // Use the new JSX transform for React, which is more efficient and compatible with modern React versions.
		"declaration": true, // Generates .d.ts files for TypeScript definitions.
		"newLine": "lf", // Use LF line endings for consistency across platforms.
		"stripInternal": true, // Strips out internal declarations from the output.
		"strict": true, // Enables all strict type-checking options.
		"erasableSyntaxOnly": true, // Only allows syntax that can be erased in the output.
		"noImplicitReturns": true, // Ensures that all code paths in a function return a value.
		"noImplicitOverride": true, // Disallows overriding methods without an explicit override modifier.
		"noUnusedLocals": true, // Reports errors on unused local variables.
		"noUnusedParameters": true, // Reports errors on unused function parameters.
		"noFallthroughCasesInSwitch": true, // Prevents fallthrough cases in switch statements.
		"noUncheckedIndexedAccess": true, // Ensures that indexed access types are checked for undefined.
		"noPropertyAccessFromIndexSignature": false, // Allows property access from index signatures, which is useful for dynamic object types.
		"noUncheckedSideEffectImports": true, // Ensures that imports with side effects are checked.
		"noEmitOnError": true, // Prevents emitting files if there are any type errors.
		"useDefineForClassFields": true, // Uses `define` semantics for class fields, which is the standard in modern JavaScript.
		"skipLibCheck": true, // Skips type checking of declaration files, which can speed up the build process.
		"isolatedModules": true // Ensures that each file can be transpiled independently, which is useful for projects using Babel or similar tools.
	},
	"exclude": ["${configDir}/dist"] // Exclude the output directory to prevent it from being included in the compilation.
}